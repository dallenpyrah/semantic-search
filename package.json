{
  "name": "@rikalabs/semantic-search",
  "version": "0.1.0",
  "description": "Effect-native semantic and hybrid code search: a Pi coding-agent extension and standalone CLI backed by TurboPuffer and OpenAI embeddings.",
  "license": "Apache-2.0",
  "type": "module",
  "keywords": [
    "pi-package",
    "semantic-search",
    "code-search",
    "effect",
    "turbopuffer",
    "embeddings"
  ],
  "bin": {
    "semsearch": "./src/cli/main.ts"
  },
  "exports": {
    ".": "./src/index.ts",
    "./pi": "./src/pi/extension.ts"
  },
  "pi": {
    "extensions": [
      "./src/pi/extension.ts"
    ],
    "skills": [
      "./skills"
    ]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src test eval",
    "test": "bun test",
    "cli": "bun src/cli/main.ts"
  },
  "dependencies": {
    "@effect/ai-openai": "4.0.0-beta.85",
    "@effect/platform-node": "4.0.0-beta.85",
    "effect": "4.0.0-beta.85",
    "typebox": "1.1.38"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^24.0.0",
    "typescript": "^6.0.0"
  }
}
